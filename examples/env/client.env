# EnvironmentFile example for examples/systemd/mvp-vpn-lite-client.service.
# The MVPVPN_CLIENT_* variables configure cmd/client. The helper variables
# configure scripts/setup-client.sh and scripts/cleanup-client.sh.

MVPVPN_CLIENT_SERVER0=server.example.com:44433
MVPVPN_CLIENT_SERVER1=server.example.com:44434
MVPVPN_CLIENT_CA_CERT=
MVPVPN_CLIENT_SERVER_NAME=
MVPVPN_CLIENT_TLS_CERT=
MVPVPN_CLIENT_TLS_KEY=
MVPVPN_CLIENT_VIRTUAL_IP=10.8.0.1
MVPVPN_CLIENT_CLIENT_IP=10.8.0.2
MVPVPN_CLIENT_STATS_INTERVAL=10s
MVPVPN_CLIENT_STATS_JSON=false
MVPVPN_CLIENT_TUN=true
MVPVPN_CLIENT_TUN_NAME=mvpvpn0
MVPVPN_CLIENT_TUN_ALLOW_CIDR=10.8.0.0/24
MVPVPN_CLIENT_RECONNECT_MIN=1s
MVPVPN_CLIENT_RECONNECT_MAX=30s

DEVICE=mvpvpn0
CLIENT_IP=10.8.0.2
PREFIX=24
MTU=1400
ROUTE=10.8.0.1/32
OWNER=root
