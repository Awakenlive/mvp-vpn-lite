# EnvironmentFile example for examples/systemd/mvp-vpn-lite-server.service.
# The MVPVPN_SERVER_* variables configure cmd/server. The helper variables
# configure scripts/setup-server.sh and scripts/cleanup-server.sh.

MVPVPN_SERVER_LISTEN0=0.0.0.0:44433
MVPVPN_SERVER_LISTEN1=0.0.0.0:44434
MVPVPN_SERVER_TLS_CERT=
MVPVPN_SERVER_TLS_KEY=
MVPVPN_SERVER_VIRTUAL_IP=10.8.0.1
MVPVPN_SERVER_CLIENT_IP=10.8.0.2
MVPVPN_SERVER_STATS_INTERVAL=10s
MVPVPN_SERVER_TUN=true
MVPVPN_SERVER_TUN_NAME=mvpvpns0

DEVICE=mvpvpns0
SERVER_IP=10.8.0.1
PREFIX=24
MTU=1400
OWNER=root
ROUTE=
